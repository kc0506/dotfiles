#!/bin/bash
{{- if eq .machine_type "csie" }}
echo ">>> [00] Setting up symlinks to /tmp2..."

# Symlink large directories to /tmp2 to save home directory space.

SYMLINK_BASE="/tmp2/$(whoami)/.symlinks"

mklink() {
    local name="$1"
    local target="$SYMLINK_BASE/$name"
    local link_path="$HOME/$name"

    mkdir -p "$target"
    mkdir -p "$(dirname "$link_path")"

    if [ -L "$link_path" ]; then
        rm -f "$link_path"
    elif [ -e "$link_path" ]; then
        echo "ERROR: $link_path already exists and is not a symlink. Please remove it manually."
        exit 1
    fi

    ln -s "$target" "$link_path"
    echo "Created symlink: $link_path -> $target"
}

mklink .gnupg
mklink .cache
mklink .cargo
mklink .rustup
mklink .npm
mklink .local/bin
mklink .local/lib
mklink .local/share
mklink miniforge3

# Convenience link
ln -sfn "/tmp2/$(whoami)" "$HOME/tmp2"
{{- end }}
