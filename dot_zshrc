del() {
    mkdir -p ~/trash
    mv "$@" ~/trash/
}

ivk() {
    # 如果沒有輸入參數，預設開啟目前資料夾 (.)
    local target="${1:-.}"

    # 判斷是否在 WSL 環境，若是則轉換路徑格式
    if command -v wslpath > /dev/null; then
        target=$(wslpath -w "$target")
    fi

    # 呼叫 pwsh.exe 執行 Invoke-Item
    # 使用單引號包裹路徑以防止 PowerShell 解析特殊字元
    win pwsh -Command "Invoke-Item '$target'"
}

clresume(){
    claude --dangerously-skip-permissions --resume $1
}

