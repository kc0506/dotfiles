del() {
    mkdir -p ~/trash
    mv "$@" ~/trash/
}

{{ if eq .machine_type "wsl" -}}
ivk() {
    local target="${1:-.}"
    if command -v wslpath > /dev/null; then
        target=$(wslpath -w "$target")
    fi
    win pwsh -Command "Invoke-Item '$target'"
}
{{ end -}}

alias gdown='uvx gdown'
alias zj=zellij
alias vim=nvim

export MANPAGER='nvim +Man!'

# Path
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/manual-bin:$PATH"
{{ if eq .machine_type "csie" -}}
export PATH="/tmp2/$(whoami)/.symlinks/.npm-global/bin:$PATH"
export LD_LIBRARY_PATH="$HOME/tmp2/local/lib:$LD_LIBRARY_PATH"
export UV_CACHE_DIR="/tmp2/$(whoami)/.cache/uv"
{{ else -}}
export PATH="$HOME/.npm-global/bin:$PATH"
{{ end -}}

# Cargo
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
{{ if eq .machine_type "wsl" -}}
plugins=(git winexec mvd zsh-python-module-completion)
{{ else -}}
plugins=(git zsh-python-module-completion)
{{ end -}}
source $ZSH/oh-my-zsh.sh

# Zellij
command -v zellij &>/dev/null && eval "$(zellij setup --generate-auto-start zsh)"

# Mise
command -v mise &>/dev/null && eval "$(mise activate zsh)"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

{{ if eq .machine_type "csie" -}}
# >>> conda initialize >>>
__conda_setup="$("$HOME/miniforge3/bin/conda" 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "$HOME/miniforge3/etc/profile.d/conda.sh" ]; then
        . "$HOME/miniforge3/etc/profile.d/conda.sh"
    else
        export PATH="$HOME/miniforge3/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<

# >>> mamba initialize >>>
export MAMBA_EXE="$HOME/miniforge3/bin/mamba"
export MAMBA_ROOT_PREFIX="$HOME/miniforge3"
__mamba_setup="$("$MAMBA_EXE" shell hook --shell zsh --root-prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__mamba_setup"
else
    alias mamba="$MAMBA_EXE"
fi
unset __mamba_setup
# <<< mamba initialize <<<
{{ end -}}
